{
    "name": "dayz-modern-economic-editor",
    "productName": "dayz-modern-economic-editor",
    "version": "0.5.2",
    "description": "This is a modern economic editor for DayZ",
    "main": "out/main/main.mjs",
    "private": true,
    "scripts": {
        "dev": "electron-vite dev",
        "build": "electron-vite build",
        "start": "electron-vite preview",
        "dist": "electron-vite build && electron-builder",
        "dist:dir": "electron-vite build && electron-builder --dir",
        "release": "electron-vite build && dotenv -e .env -- electron-builder --publish always",
        "lint": "eslint --ext .ts,.tsx ."
    },
    "keywords": [],
    "author": "Alexey Efremov",
    "license": "MIT",
    "build": {
        "appId": "com.alexefremov.dayz-modern-economic-editor",
        "productName": "DayZ Modern Economic Editor",
        "directories": {
            "output": "release"
        },
        "files": [
            "out/**/*",
            "!node_modules/**/*"
        ],
        "asar": true,
        "win": {
            "target": "nsis"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true
        },
        "publish": {
            "provider": "github",
            "owner": "rakotoz",
            "repo": "dayzModernEconomicEditor"
        }
    },
    "devDependencies": {
        "@typescript-eslint/eslint-plugin": "^5.62.0",
        "@typescript-eslint/parser": "^5.62.0",
        "dotenv-cli": "^11.0.0",
        "electron": "42.0.0",
        "electron-builder": "^26.15.3",
        "electron-vite": "^5.0.0",
        "eslint": "9.26.0",
        "eslint-plugin-import": "^2.32.0",
        "typescript": "~4.5.4",
        "vite": "8.0.5"
    },
    "dependencies": {
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@fontsource/roboto": "^5.2.10",
        "@mui/icons-material": "^9.0.1",
        "@mui/material": "^9.0.1",
        "@mui/styled-engine-sc": "^9.0.1",
        "@mui/x-data-grid": "^9.0.1",
        "@reduxjs/toolkit": "^2.11.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "electron-updater": "^6.8.9",
        "i18next": "^26.0.10",
        "prettier": "^3.8.3",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "react-i18next": "^17.0.7",
        "react-redux": "^9.1.2",
        "react-router": "^7.15.0",
        "styled-components": "^6.4.1",
        "xml2js": "^0.6.2"
    }
}
